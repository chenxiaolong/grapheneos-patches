Subject: [PATCH 1/2] Use Pixel default boot animation

---
 config/device/common/file-exclusion.yml | 2 --
 config/device/common/file-inclusion.yml | 2 ++
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/config/device/common/file-exclusion.yml b/config/device/common/file-exclusion.yml
index 9559ef0f9..2de6255a1 100644
--- a/config/device/common/file-exclusion.yml
+++ b/config/device/common/file-exclusion.yml
@@ -68,8 +68,6 @@ filters:
       - product/fonts/ZillaSlab-SemiBoldItalic.ttf
       - product/framework/com.google.android.dialer.support.jar
       - product/framework/libhwinfo.jar
-      - product/media/bootanimation-dark.zip
-      - product/media/bootanimation.zip
       - product/priv-app/DMService/lib/arm/libdmengine.so
       - product/priv-app/DMService/lib/arm/libdmjavaplugin.so
       - product/priv-app/DMService/lib/arm64/libdmengine.so
diff --git a/config/device/common/file-inclusion.yml b/config/device/common/file-inclusion.yml
index cf6069b7d..082d247c8 100644
--- a/config/device/common/file-inclusion.yml
+++ b/config/device/common/file-inclusion.yml
@@ -2,6 +2,8 @@ filters:
   file_inclusions:
     prefix:
       - product/etc/CarrierSettings/
+      - product/media/bootanimation-dark.zip
+      - product/media/bootanimation.zip
       - recovery/init.recovery.
       - recovery/res/images/loop000
       - vendor/etc/bluetooth_power_limits
